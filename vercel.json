{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "5 16 * * *"
    },
    {
      "path": "/api/cron/ai",
      "schedule": "15 16 * * *"
    },
    {
      "path": "/api/cron/meteo-vigilance",
      "schedule": "5 15,1 * * *"
    },
    {
      "path": "/api/cron/evening-push",
      "schedule": "0 3 * * 0,4,5,6"
    },
    {
      "path": "/api/cron/facebook",
      "schedule": "30 17 * * *"
    },
    {
      "path": "/api/cron/weekly-newsletter",
      "schedule": "0 4 * * 1"
    }
  ],
  "functions": {
    "src/app/api/cron/garde-weekend/route.ts": {
      "memory": 1024,
      "maxDuration": 300,
      "includeFiles": "node_modules/tesseract.js-core/**"
    },
    "src/app/api/cron/ai/route.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/cron/daily/route.ts": {
      "memory": 1024,
      "maxDuration": 300,
      "includeFiles": "node_modules/tesseract.js-core/**"
    },
    "src/app/api/cron/aggregate/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "src/app/api/cron/facebook/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "src/app/api/cron/weekly-recap/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    },
    "src/app/api/cron/weekly-newsletter/route.ts": {
      "memory": 1024,
      "maxDuration": 300
    }
  }
}
